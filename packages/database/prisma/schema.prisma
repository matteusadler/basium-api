// Basium CRM Imobiliário - Prisma Schema v1.0
// PostgreSQL + pgvector

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ────────────────────────────────────────────────────────────────
// ENUMS (MongoDB usa strings internamente)
// ────────────────────────────────────────────────────────────────

enum Role {
  CORRETOR
  GERENTE
  ADMIN
  SUPER_ADMIN
}

enum PlanStatus {
  TRIAL
  ACTIVE
  OVERDUE
  CANCELLED
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

enum Temperature {
  HOT
  WARM
  COLD
  FREEZING
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageSender {
  USER
  AI
  HUMAN_AGENT
  FLOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
  OVERDUE
}

enum TaskType {
  CALL
  WHATSAPP
  VISIT
  MEETING
  PROPOSAL
  OTHER
}

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ExecStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  WAITING
}

enum StepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum SuggestionType {
  REPLY
  STRATEGY
  NEXT_ACTION
  ALERT
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

// ────────────────────────────────────────────────────────────────
// COMPANY & PLANS
// ────────────────────────────────────────────────────────────────

model Company {
  id               String           @id @default(cuid())
  name             String
  cnpj             String?
  logo             String?
  planId           String
  planStatus       PlanStatus       @default(TRIAL)
  trialEndsAt      DateTime?
  stripeCustomerId String?          @unique
  stripeSubId      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  users            User[]
  leads            Lead[]
  pipelines        Pipeline[]
  flows            Flow[]
  documents        Document[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]
  properties       Property[]
  owners           Owner[]
  contracts        Contract[]
  commissions      Commission[]
  financialEntries FinancialEntry[]
  dailyInsights    DailyInsight[]
  portalConfig     PortalConfig?
  usage            CompanyUsage?
  notifications    Notification[]
  tasks            Task[]
  condominiums     Condominium[]
}

model Plan {
  id                   String  @id @default(cuid())
  name                 String
  stripePriceIdMonthly String
  stripePriceIdYearly  String
  maxLeads             Int
  maxUsers             Int
  maxWhatsappNumbers   Int
  maxPipelines         Int
  maxFlows             Int
  maxFlowExecutions    Int
  storageGb            Float
  hasAi                Boolean @default(false)
  hasCopilot           Boolean @default(false)
  hasFlowBuilder       Boolean @default(false)
  hasPortals           Boolean @default(false)
  trialDays            Int     @default(7)
}

model Subscription {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stripeSubId        String    @unique
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
}

model CompanyUsage {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leadsCount      Int      @default(0)
  usersCount      Int      @default(0)
  propertiesCount Int      @default(0)
  contractsCount  Int      @default(0)
  activeFlows     Int      @default(0)
  flowExecMonth   Int      @default(0)
  storageBytes    BigInt   @default(0)
  pdfCount        Int      @default(0)
  updatedAt       DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────
// USER & AUTH
// ────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email              String    @unique
  name               String
  passwordHash       String?
  role               Role      @default(CORRETOR)
  avatarUrl          String?
  isActive           Boolean   @default(true)
  emailVerified      Boolean   @default(false)
  openaiKey          String?
  wabaId             String?
  phoneNumberId      String?
  waAccessToken      String?
  waPhone            String?
  waConnectedAt      DateTime?
  aiSystemPrompt     String?
  aiEnabled          Boolean   @default(false)
  aiWorkingHours     Json?
  aiMaxMessages      Int       @default(10)
  aiTransferKeywords String[]
  pushSubscription   Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  notifications      Notification[]
}

// ────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  type      String   // NEW_LEAD, LEAD_STAGE_CHANGED, TASK_DUE_TODAY, CONTRACT_SIGNED
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([userId, read, createdAt])
}

// ────────────────────────────────────────────────────────────────
// CRM - PIPELINES & STAGES
// ────────────────────────────────────────────────────────────────

model Pipeline {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  type      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  stages    Stage[]
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stage {
  id          String   @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  color       String   @default("#6366f1")
  order       Int
  probability Float    @default(50)
  type        String
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────
// CRM - LEADS
// ────────────────────────────────────────────────────────────────

model Lead {
  id                   String                 @id @default(cuid())
  companyId            String
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId               String
  name                 String
  phone                String
  email                String?
  cpf                  String?
  clientType           String?
  origin               String
  temperature          Temperature            @default(COLD)
  priority             Priority               @default(MEDIUM)
  tags                 String[]
  propertyTypes        String[]
  minValue             Float?
  maxValue             Float?
  neighborhoods        String[]
  bedrooms             Int?
  suites               Int?
  parkingSpots         Int?
  minArea              Float?
  features             String[]
  paymentType          String?
  hasPropertySwap      Boolean                @default(false)
  financingStatus      String?
  monthlyIncome        Float?
  purchaseDeadline     String?
  pipelineId           String
  pipeline             Pipeline               @relation(fields: [pipelineId], references: [id])
  stageId              String
  stage                Stage                  @relation(fields: [stageId], references: [id])
  estimatedValue       Float?
  probability          Float?
  nextAction           String?
  nextActionDate       DateTime?
  lostReason           String?
  lostNote             String?
  closedValue          Float?
  closedAt             DateTime?
  status               LeadStatus             @default(ACTIVE)
  isFavorite           Boolean                @default(false)
  lastInteraction      DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  conversations        Conversation[]
  tasks                Task[]
  notes                Note[]
  attachments          Attachment[]
  historyEvents        LeadHistory[]
  flowExecutions       FlowExecution[]
  contracts            Contract[]
  interestedProperties LeadPropertyInterest[]

  @@index([companyId, status])
  @@index([companyId, stageId])
  @@index([companyId, userId])
  @@index([pipelineId])
}

model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([leadId, createdAt])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────
// CRM - TASKS
// ────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  description String?
  type        TaskType
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime
  dueTime     String?
  result      String?
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
}

// ────────────────────────────────────────────────────────────────
// WHATSAPP - CONVERSATIONS & MESSAGES
// ────────────────────────────────────────────────────────────────

model Conversation {
  id            String         @id @default(cuid())
  companyId     String
  leadId        String
  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId        String
  phone         String
  isBotActive   Boolean        @default(true)
  aiAssistMode  Boolean        @default(false)
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      Message[]
  aiSuggestions AiSuggestion[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  type           String
  direction      MessageDirection
  sender         MessageSender
  status         MessageStatus    @default(SENT)
  mediaUrl       String?
  metaMessageId  String?
  createdAt      DateTime         @default(now())
}

// ────────────────────────────────────────────────────────────────
// AI - SUGGESTIONS (Co-Pilot)
// ────────────────────────────────────────────────────────────────

model AiSuggestion {
  id               String         @id @default(cuid())
  conversationId   String
  conversation     Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  leadId           String
  suggestedText    String
  suggestionType   SuggestionType
  used             Boolean        @default(false)
  usedAt           DateTime?
  editedBeforeSend Boolean        @default(false)
  createdAt        DateTime       @default(now())
}

// ────────────────────────────────────────────────────────────────
// AI - DOCUMENTS (RAG) - DocumentChunk DESABILITADO (requer pgvector)
// ────────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  url       String
  size      Int
  status    String   @default("PROCESSING")
  createdAt DateTime @default(now())
}

