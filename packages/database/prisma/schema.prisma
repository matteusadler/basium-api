// ────────────────────────────────────────────────────────────────
// FLOW BUILDER
// ────────────────────────────────────────────────────────────────

model Flow {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       FlowStatus      @default(DRAFT)
  nodes        Json
  edges        Json
  triggerTypes String[]
  keywords     String[]
  version      Int             @default(1)
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  executions   FlowExecution[]
}

model FlowExecution {
  id            String     @id @default(cuid())
  flowId        String
  flow          Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  companyId     String
  leadId        String
  lead          Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactPhone  String
  status        ExecStatus @default(RUNNING)
  currentNodeId String?
  variables     Json       @default("{}")
  startedAt     DateTime   @default(now())
  completedAt   DateTime?
  steps         FlowStep[]

  @@index([companyId])
  @@index([flowId])
  @@index([leadId])
}

model FlowStep {
  id          String        @id @default(cuid())
  executionId String
  execution   FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId      String
  nodeType    String
  status      StepStatus    @default(PENDING)
  input       Json?
  output      Json?
  error       String?
  executedAt  DateTime      @default(now())
  duration    Int?
}

model FlowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  nodes       Json
  edges       Json
  isPublic    Boolean  @default(false)
  companyId   String?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────
// AUDIT LOG (LGPD)
// ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String
  action     String
  entityId   String?
  entityType String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────
// ERP - PROPERTY (Imóvel)
// ────────────────────────────────────────────────────────────────

model Property {
  id                 String                 @id @default(cuid())
  companyId          String
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code               String
  type               String
  purpose            String
  status             String
  street             String
  number             String
  complement         String?
  neighborhood       String
  city               String
  state              String
  zipCode            String
  latitude           Float?
  longitude          Float?
  condominiumId      String?
  condominium        Condominium?           @relation(fields: [condominiumId], references: [id])
  totalArea          Float?
  builtArea          Float?
  privateArea        Float?
  bedrooms           Int?
  suites             Int?
  bathrooms          Int?
  parkingSpots       Int?
  floor              Int?
  features           String[]
  salePrice          Float?
  rentPrice          Float?
  iptuYearly         Float?
  condoMonthly       Float?
  acceptsSwap        Boolean                @default(false)
  registrationNumber String?
  legalStatus        String?
  availableFrom      DateTime?
  description        String?
  aiDescription      String?
  publishOnPortals   Boolean                @default(false)
  zapPublished       Boolean                @default(false)
  vivarealPublished  Boolean                @default(false)
  olxPublished       Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  owners             PropertyOwner[]
  media              PropertyMedia[]
  contracts          Contract[]
  interestedLeads    LeadPropertyInterest[]
}

model PropertyMedia {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type         String
  url          String
  thumbnailUrl String?
  order        Int
  isCover      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model LeadPropertyInterest {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())
  contacted  Boolean  @default(false)

  @@unique([leadId, propertyId])
}

// ────────────────────────────────────────────────────────────────
// ERP - OWNER (Proprietário)
// ────────────────────────────────────────────────────────────────

model Owner {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  cpfCnpj     String
  phone       String
  email       String?
  address     String?
  bankName    String?
  bankAgency  String?
  bankAccount String?
  accountType String?
  pixKey      String?
  pixKeyType  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  properties  PropertyOwner[]
}

model PropertyOwner {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownershipPct Float    @default(100)
}

model Condominium {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  cnpj         String?
  address      String
  syndicName   String?
  adminCompany String?
  monthlyFee   Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  properties   Property[]
}

// ────────────────────────────────────────────────────────────────
// ERP - CONTRACT
// ────────────────────────────────────────────────────────────────

model Contract {
  id                   String              @id @default(cuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type                 String
  status               String
  propertyId           String
  property             Property            @relation(fields: [propertyId], references: [id])
  leadId               String
  lead                 Lead                @relation(fields: [leadId], references: [id])
  brokerId             String
  captorId             String?
  salePrice            Float?
  paymentType          String?
  bankName             String?
  financedAmount       Float?
  interestRate         Float?
  termMonths           Int?
  signedAt             DateTime?
  deedAt               DateTime?
  keysDeliveredAt      DateTime?
  rentAmount           Float?
  startDate            DateTime?
  durationMonths       Int?
  dueDayOfMonth        Int?
  adjustmentIndex      String?
  adjustmentFrequency  Int?
  nextAdjustmentDate   DateTime?
  guaranteeType        String?
  depositAmount        Float?
  penaltyPct           Float?
  stripeSubscriptionId String?
  documents            ContractDocument[]
  commissions          Commission[]
  financialEntries     FinancialEntry[]
  adjustmentHistory    AdjustmentHistory[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model ContractDocument {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name       String
  url        String
  type       String
  uploadedAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────
// ERP - COMMISSION
// ────────────────────────────────────────────────────────────────

model Commission {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractId    String
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  recipientId   String
  recipientType String
  recipientName String
  baseValue     Float
  percentage    Float
  amount        Float
  status        String
  dueDate       DateTime?
  paidAt        DateTime?
  receiptUrl    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ────────────────────────────────────────────────────────────────
// ERP - FINANCIAL ENTRY
// ────────────────────────────────────────────────────────────────

model FinancialEntry {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractId      String?
  contract        Contract? @relation(fields: [contractId], references: [id])
  type            String
  category        String
  description     String
  amount          Float
  dueDate         DateTime
  paidAt          DateTime?
  status          String
  paymentMethod   String?
  receiptUrl      String?
  stripeInvoiceId String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ────────────────────────────────────────────────────────────────
// ERP - ADJUSTMENT HISTORY
// ────────────────────────────────────────────────────────────────

model AdjustmentHistory {
  id             String   @id @default(cuid())
  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  appliedAt      DateTime @default(now())
  indexUsed      String
  indexValue     Float
  previousValue  Float
  newValue       Float
  referenceMonth String
}

// ────────────────────────────────────────────────────────────────
// ERP - AI INSIGHTS
// ────────────────────────────────────────────────────────────────

model DailyInsight {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────
// PORTAL - CONFIG
// ────────────────────────────────────────────────────────────────

model PortalConfig {
  id              String     @id @default(cuid())
  companyId       String     @unique
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subdomain       String     @unique
  customDomain    String?    @unique
  sslProvisioned  Boolean    @default(false)
  isActive        Boolean    @default(true)
  logo            String?
  favicon         String?
  primaryColor    String     @default("#1A3C6E")
  secondaryColor  String     @default("#2563A8")
  fontFamily      String     @default("Inter")
  coverPhoto      String?
  brokerPhoto     String?
  bio             String?
  creci           String?
  instagram       String?
  facebook        String?
  linkedin        String?
  youtube         String?
  whatsappNumber  String?
  gaId            String?
  metaPixelId     String?
  showWatermark   Boolean    @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  blogPosts       BlogPost[]
}

model BlogPost {
  id              String       @id @default(cuid())
  companyId       String
  portalConfig    PortalConfig @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  title           String
  slug            String
  content         String
  excerpt         String?
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  tags            String[]
  isPublished     Boolean      @default(false)
  publishedAt     DateTime?
  aiGenerated     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([companyId, slug])
}

model PortalAnalytics {
  id             String   @id @default(cuid())
  companyId      String
  date           DateTime
  pageViews      Int      @default(0)
  uniqueVisitors Int      @default(0)
  leadsGenerated Int      @default(0)
  propertyId     String?
  source         String?
  createdAt      DateTime @default(now())
}
